<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ForestQuest" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/forest_primary</item>
        <item name="colorPrimaryVariant">@color/forest_primary_dark</item>
        <item name="colorOnPrimary">@color/forest_on_primary</item>
        <item name="colorSecondary">@color/forest_accent</item>
        <item name="colorOnSecondary">@color/forest_on_surface</item>
        <item name="android:windowBackground">@color/forest_background</item>
    </style>

    <style name="Theme.ForestQuest.Fullscreen" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
