<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#8ED081"
                android:centerColor="#6CC6FF"
                android:endColor="#4FA3F7"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <solid android:color="#332E7D32" />
        </shape>
    </item>
</layer-list>
