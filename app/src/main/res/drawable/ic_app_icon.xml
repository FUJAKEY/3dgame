<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="90"
                android:endColor="#66C56C"
                android:startColor="#2E7D32" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:bottom="26dp">
        <shape android:shape="rectangle">
            <solid android:color="#5D4037" />
            <size android:width="12dp" android:height="28dp" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item
        android:bottom="36dp"
        android:gravity="center">
        <shape android:shape="oval">
            <size android:width="64dp" android:height="64dp" />
            <solid android:color="#A5D6A7" />
        </shape>
    </item>
</layer-list>
